<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Full Regression Suite" verbose="1">
    <test name="Positive Login Tests">
        <classes>
            <class name="com.practicetestautomtation.tests.login.LoginTest">
                <methods>
                    <include name="testLoginFunctionality"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Negative Login Tests">
        <groups>
            <run>
                <exclude name="positive"/>
            </run>
        </groups>
        <classes>
            <class name="com.practicetestautomtation.tests.login.LoginTest"/>
        </classes>
    </test>
</suite>