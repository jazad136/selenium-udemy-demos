<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Smoke Test Suite" verbose="1">
    <listeners>
        <listener class-name="com.practicetestautomation.listener.TestInfoPrintListener"/>
    </listeners>
    <test name="Login Tests">
        <groups>
            <run>
                  <include name="smoke"></include>
            </run>
        </groups>
        <classes>
            <class name="com.practicetestautomation.tests.factorylogin.NewLoginTest">
                <methods>
                    <!--<include name="testLoginFunctionality"/>-->
                    <include name="negativeLoginTest"/>
                    <!--<include name="LoginTestFactory"/>-->
                </methods>
            </class>
        </classes>
    </test>
</suite>
