<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">


<suite name="Negative Test Suite" verbose="1">
    <listeners>
        <listener class-name="com.practicetestautomation.listener.TestInfoListener"/>
    </listeners>
    <test name="Incorrect Username Test">
        <classes>
            <class name="com.practicetestautomation.tests.login.LoginTest">
                <methods>
                    <include name="negativeLoginTest"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Incorrect Password Test">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.practicetestautomation.tests.login.LoginTest">
                <methods>
                    <include name="negativeLoginTest"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>

